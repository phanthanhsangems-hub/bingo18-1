# ── Copy file này thành .env và điền giá trị thật ──────────────
# cp .env.example .env

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Admin & Security
ADMIN_SECRET_KEY=your_strong_random_key_here
TRIGGER_SECRET=your_strong_random_key_here

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/postgres
SUPABASE_PASSWORD=your_supabase_password_here

# AI APIs (dùng trong ai_predictor.py)
OPENROUTER_API_KEY=sk-or-v1-xxx
GROQ_API_KEY=gsk_xxx
GEMINI_API_KEY=AIzaSy_xxx

# CORS - chỉ định domain được phép gọi API (để * nếu public)
CORS_ORIGINS=https://your-app.run.app

# Optional
LOG_LEVEL=INFO
PORT=8080

# ── Win threshold ──────────────────────────────────────────────
# 1 = khớp 1/3 (dễ, random baseline=87.5%)
# 2 = khớp 2/3 (khó, random baseline=35.6%) ← khuyến nghị
WIN_THRESHOLD=1
